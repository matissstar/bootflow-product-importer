#!/usr/bin/env php
<?php
/**
 * Bootflow Product Importer - Auto Translation Generator
 * 
 * Generates translation JSON files for all supported languages.
 * Uses comprehensive phrase dictionaries + pattern matching.
 * 
 * Usage: php auto-translate.php
 * Output: languages/translations/{locale}.json
 */

$lang_dir = __DIR__;
$template = json_decode(file_get_contents($lang_dir . '/translations/template.json'), true);
$strings = array_keys($template);

echo "=== Auto Translation Generator ===\n";
echo count($strings) . " strings to translate\n\n";

// Language configs
$locales = [
    'lv', 'es_ES', 'de_DE', 'fr_FR', 'pt_BR',
    'ja', 'it_IT', 'nl_NL', 'ru_RU', 'zh_CN',
    'pl_PL', 'tr_TR', 'sv_SE', 'id_ID', 'ar'
];

foreach ($locales as $locale) {
    echo "Generating {$locale}...\n";
    $dict = load_dictionary($locale);
    $result = [];
    $translated = 0;
    
    foreach ($strings as $s) {
        $t = translate_string($s, $dict, $locale);
        $result[$s] = $t;
        if ($t !== '' && $t !== $s) $translated++;
    }
    
    $outfile = $lang_dir . "/translations/{$locale}.json";
    file_put_contents($outfile, json_encode($result, JSON_UNESCAPED_UNICODE | JSON_PRETTY_PRINT | JSON_UNESCAPED_SLASHES));
    echo "  → {$translated}/" . count($strings) . " translated (" . round($translated/count($strings)*100) . "%)\n";
}

echo "\nDone! Run 'php generate-translations.php' to create .po/.mo files.\n";

// ============================================================

function translate_string($s, $dict, $locale) {
    // 1. Skip numbers, code fragments, variables
    if (preg_match('/^[0-9.,]+$/', $s)) return $s;
    if (preg_match('/^\$/', $s)) return $s;
    if ($s === '' || strlen($s) < 2) return $s;
    
    // 2. Exact match in dictionary
    if (isset($dict['phrases'][$s])) return $dict['phrases'][$s];
    
    // 3. Case-insensitive exact match
    $lower = mb_strtolower($s);
    foreach ($dict['phrases'] as $k => $v) {
        if (mb_strtolower($k) === $lower) return $v;
    }
    
    // 4. Pattern-based translation (handles %s, %d placeholders)
    foreach ($dict['patterns'] as $pattern => $replacement) {
        if (preg_match($pattern, $s)) {
            $result = preg_replace($pattern, $replacement, $s);
            if ($result !== $s) return $result;
        }
    }
    
    // 5. Word-by-word for short strings (1-3 words)
    $word_count = str_word_count($s);
    if ($word_count <= 3 && isset($dict['words'])) {
        $result = translate_words($s, $dict['words'], $locale);
        if ($result !== $s) return $result;
    }
    
    // 6. Not translated - return empty (English will be used as fallback)
    return '';
}

function translate_words($s, $words, $locale) {
    // Preserve leading/trailing spaces, dashes, etc.
    $result = $s;
    
    // Try multi-word replacements first (longer phrases first)
    $sorted_words = $words;
    uksort($sorted_words, function($a, $b) { return strlen($b) - strlen($a); });
    
    foreach ($sorted_words as $en => $tr) {
        $pattern = '/\b' . preg_quote($en, '/') . '\b/i';
        $new_result = preg_replace($pattern, $tr, $result);
        if ($new_result !== null) $result = $new_result;
    }
    
    return $result;
}

function load_dictionary($locale) {
    $common_phrases = get_common_phrases($locale);
    $common_words = get_common_words($locale);
    $patterns = get_patterns($locale);
    
    return [
        'phrases' => $common_phrases,
        'words' => $common_words,
        'patterns' => $patterns,
    ];
}

function get_patterns($locale) {
    // Common pattern replacements
    return [];
}

