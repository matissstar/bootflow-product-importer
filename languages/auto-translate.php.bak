// This file is split - see auto-translate-phrases.php for the phrase dictionaries
function get_common_phrases($locale) {
    $file = __DIR__ . "/translations/phrases-{$locale}.php";
    if (file_exists($file)) {
        return include $file;
    }
    return [];
}
